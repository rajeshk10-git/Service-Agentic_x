{
  "name": "financial-wellness-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Personal Financial Wellness AI Agent backend",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
