    "@google-cloud/vertexai": "^1.9.2",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.14.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "openai": "^4.77.0",
    "pg": "^8.13.1"
