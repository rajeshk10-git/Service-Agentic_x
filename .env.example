# --- Core ---
APP_PORT=3000
DATABASE_URL="postgresql://user:password@localhost:5432/financial_wellness?schema=public"

# Auth (optional JWT; if unset, register/login still work but omit `token` in response)
JWT_SECRET=
JWT_EXPIRES_DAYS=7
# bcrypt cost (4–14). Lower = faster registration, e.g. BCRYPT_ROUNDS=8 for local dev only
BCRYPT_ROUNDS=10

# LLM: gemini | google-ai (Gemini Developer API + GOOGLE_AI_API_KEY, like generativelanguage.googleapis.com?key=)
#       vertex (Vertex AI + gcloud ADC) | openai
# If LLM_PROVIDER is unset: uses google-ai when GOOGLE_AI_API_KEY is set, else openai if OPENAI_API_KEY, else vertex.
LLM_PROVIDER=gemini

# OpenAI (only when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini Developer API (LLM_PROVIDER=gemini or google-ai). Same key as ?key= on generativelanguage.googleapis.com
GOOGLE_AI_API_KEY=
# Optional alias for the same key:
# GEMINI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash

# Gemini on Vertex (when LLM_PROVIDER=gemini or vertex). Uses Application Default Credentials.
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
VERTEX_GEMINI_MODEL=gemini-1.5-flash

# Python microservices (optional)
PYTHON_TAX_SERVICE_URL=http://localhost:8001
PYTHON_PARSE_SERVICE_URL=http://localhost:8000

# Cloud Logging style logs on Cloud Run or force JSON
# LOG_FORMAT=json

# --- Optional: Secret Manager bootstrap (set before dynamic imports; use with server GCP_SECRET_MANAGER_ENABLED) ---
GCP_SECRET_MANAGER_ENABLED=false
GCP_SM_DATABASE_URL=
GCP_SM_OPENAI_API_KEY=

# --- GCS payslip uploads ---
GCS_PAYSLIP_BUCKET=
GCS_PAYSLIP_PREFIX=payslips
GCS_SIGNED_URL_TTL_MIN=15

# --- Document AI (processor id only, or full projects/.../processors/ID) ---
# Location must match the regional endpoint, e.g. us → us-documentai.googleapis.com
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us

# Payroll context for the agent uses PostgreSQL + in-process keyword match only (no Vertex Vector Search).

# --- Cloud Tasks async parse ---
CLOUD_TASKS_ENABLED=false
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE=parse-queue
CLOUD_TASKS_TARGET_URL=https://YOUR-SERVICE.run.app/internal/tasks/parse
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=
INTERNAL_TASKS_SECRET=change-me-in-production
